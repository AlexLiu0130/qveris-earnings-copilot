{
  "name": "qveris-earnings-copilot",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "NEXT_DIST_DIR=.next-codex next dev --webpack",
    "build": "next build --webpack",
    "build:codex": "NEXT_DIST_DIR=.next-codex next build --webpack",
    "build:sites": "node scripts/build-sites-secret-safe.mjs",
    "build:worker": "opennextjs-cloudflare build --config deploy/wrangler.jsonc",
    "scan:dist-secrets": "node scripts/scan-dist-secrets.mjs",
    "db:generate": "drizzle-kit generate",
    "start": "NEXT_DIST_DIR=.next-codex next start",
    "test": "node --import tsx --test 'lib/**/*.test.ts' 'app/**/*.test.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "drizzle-orm": "0.45.2",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.10.0",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "0.31.10",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "wrangler": "4.110.0"
  }
}
